    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "expo-server-sdk": "^3.10.0",
    "express": "^4.18.3",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.0.1",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "mercadopago": "^3.0.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "prisma": "^5.10.0",
