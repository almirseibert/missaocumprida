# =============================================
# MISSÃO CUMPRIDA — Variáveis de Ambiente
# =============================================
# Copie este arquivo para .env e preencha os valores

# Servidor
NODE_ENV=development
PORT=3333

# Banco de Dados PostgreSQL
DATABASE_URL="postgresql://USUARIO:SENHA@localhost:5432/missaocumprida?schema=public"

# JWT
JWT_SECRET=sua_chave_secreta_super_segura_aqui_minimo_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=outra_chave_secreta_para_refresh_token
JWT_REFRESH_EXPIRES_IN=7d

# Upload de arquivos
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# URL da API (para gerar links de arquivos)
API_URL=http://localhost:3333

# Cloudflare R2 (produção — deixar vazio em dev)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# URL do Frontend (para redirects do Stripe)
FRONTEND_URL=http://localhost:3000

# Stripe (fase 2)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Mercado Pago (PIX) — usar credenciais de TEST em desenvolvimento
MP_ACCESS_TOKEN=TEST-...
MP_PUBLIC_KEY=TEST-...
MP_WEBHOOK_SECRET=...
# Em produção, substituir pelas credenciais de produção (APP_USR-...)

# Twilio SMS/WhatsApp (fase 2)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ---- Push notifications ----
# Expo Push (mobile) — opcional; gere em https://expo.dev/settings/access-tokens se quiser autenticar push enhanced
EXPO_ACCESS_TOKEN=

# Web Push (frontend) — VAPID keys
# Gerar com: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=BDxY1PBtyjBvb837Wgm143L-aiExFRi3xftTgR9fPuATddyp7ZFmhaZikP6z2vR9818MSZlwoutKVSNSEyk4kqM
VAPID_PRIVATE_KEY=ORo-fRtKuiVEGY2ElBNh1mFwF76d4ucg-ICQKZlwym0
VAPID_SUBJECT=mailto:contato@missaocumprida.app
